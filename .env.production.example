# Generated by GitHub Actions during production deployment.
# Do not copy real secrets into this file.

DOCKERHUB_IMAGE=your-dockerhub-namespace/verrify-backend
GITHUB_SHA=commit-sha

PORT=3000
APP_PROFILE=prod
NODE_ENV=production
FRONTEND_HOST=https://your-frontend-domain.example
ORIGIN=https://your-frontend-domain.example

DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=replace-with-github-secret
DB_PASSWORD=replace-with-github-secret
DB_NAME=verrify
DB_TYPE=postgres
DB_SSL=false

RABBITMQ_USERNAME=replace-with-github-secret
RABBITMQ_PASSWORD=replace-with-github-secret
RABBITMQ_URI=amqp://replace-with-github-secret:replace-with-github-secret@rabbitmq:5672

EMAIL_PROVIDER=smtp
EMAIL_RESEND_API_KEY=
EMAIL_USERNAME=replace-with-github-secret
EMAIL_PASSWORD=replace-with-github-secret
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_REQUIRE_TLS=true
EMAIL_SENDER=noreply@example.com
ADMIN_EMAIL=admin@example.com

JWT_SECRET=replace-with-github-secret
JWT_EXPIRE=15m
REFRESH_EXPIRE=24
VERIFICATION_EXPIRE=15

LOG_FILE_PATH=/logs

CLOUDINARY_CLOUD_NAME=replace-with-github-secret
CLOUDINARY_API_KEY=replace-with-github-secret
CLOUDINARY_API_SECRET=replace-with-github-secret

GOOGLE_CLIENT_EMAIL=replace-with-github-secret
GOOGLE_PRIVATE_KEY=replace-with-github-secret
GOOGLE_SHEET_ID=replace-with-github-secret
GOOGLE_SHEET_NAME=replace-with-github-secret

PAYSTACK_PUBLIC_KEY=replace-with-github-secret
PAYSTACK_SECRET_KEY=replace-with-github-secret
